{
  "name": "das_buddy",
  "image": "mcr.microsoft.com/devcontainers/python:3.13",

  // Docker-in-Docker so we can run docker compose inside the Codespace
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },

  // Forward MCP server ports so the local exe can reach them
  "forwardPorts": [8001, 8002],
  "portsAttributes": {
    "8001": { "label": "Jira MCP Server",    "onAutoForward": "silent" },
    "8002": { "label": "Postman MCP Server", "onAutoForward": "silent" }
  },

  // Build and start both MCP server containers every time the Codespace starts
  "postStartCommand": "bash .devcontainer/start-servers.sh",

  // Set these as Codespace secrets in your repo settings:
  //   Settings → Secrets and variables → Codespaces
  "secrets": {
    "JIRA_URL":       { "description": "Jira instance base URL" },
    "JIRA_EMAIL":     { "description": "Atlassian account email" },
    "JIRA_API_TOKEN": { "description": "Jira API token" }
  }
}
